     🔹 1. PHP Condition Check
                $x = "0";
                if($x){
                    echo 'true';
                }else{
                    echo 'false';
                }
                ✅ Output:
                
                👉 false
                
                💡 Explanation:
                
                In PHP, "0" is considered false in boolean context.
                
        🔹 2. Continue Statement
                for($i=0;$i<=10;$i++){
                    if($i==4){
                        continue;
                    }
                    echo $i.'<br/>';
                }
                ✅ Output:
                0
                1
                2
                3
                5
                6
                7
                8
                9
                10
                💡 Explanation:
                continue skips only the current iteration
                So 4 is skipped
        🔹 3. Break Statement
                for($i=0;$i<=10;$i++){
                    if($i==4){
                        break;
                    }
                    echo $i.'<br/>';
                }
                ✅ Output:
                0
                1
                2
                3
                💡 Explanation:
                break stops the loop completely when $i == 4
        🔹 4. Variable Variables
                $father = "mother";
                $mother = "son";
                echo $$father;
                ✅ Output:
                
                👉 son
                
                💡 Explanation:
                $father = "mother"
                $$father → $mother
                $mother = "son"
        🔹 5. Remove Duplicates from Array
                $array = array('0','2','3','3','4','5','5','6');
                $result = array_unique($array);
                print_r($result);
                ✅ Output:
                Array ( [0] => 0 [1] => 2 [2] => 3 [4] => 4 [5] => 5 [7] => 6 )
                💡 Explanation:
                array_unique() removes duplicate values
                Keys are preserved
                
                👉 If you want reindex:
                
                $result = array_values(array_unique($array));
